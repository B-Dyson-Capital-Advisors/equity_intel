# Example secrets configuration for Streamlit deployment
#
# For local development:
# 1. Copy this file to .streamlit/secrets.toml
# 2. Replace the values with your actual API keys
# 3. The .gitignore will prevent secrets.toml from being committed
#
# For Streamlit Cloud deployment:
# 1. Go to your app settings in Streamlit Cloud
# 2. Navigate to the "Secrets" section
# 3. Add the content below with your actual API keys

# OpenAI API Key (if using AI features)
OPENAI_API_KEY = "sk-your-openai-api-key-here"

# Financial Modeling Prep API Key (for market data)
FMP_API_KEY = "your_fmp_api_key_here"
